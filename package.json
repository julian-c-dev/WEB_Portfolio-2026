{
  "name": "portfolio_2026",
  "version": "1.0.0",
  "description": "WordPress theme with Tailwind CSS",
  "scripts": {
    "dev:css": "tailwindcss -i ./assets/src/css/app.css -o ./assets/dist/css/app.css --watch",
    "dev:js": "esbuild ./assets/src/js/app.js --bundle --outfile=./assets/dist/js/app.js --watch",
    "dev": "npm-run-all --parallel dev:*",
    "build:css": "tailwindcss -i ./assets/src/css/app.css -o ./assets/dist/css/app.css --minify",
    "build:js": "esbuild ./assets/src/js/app.js --bundle --minify --outfile=./assets/dist/js/app.js",
    "build": "npm-run-all build:*",
    "lint:php": "vendor\\bin\\phpcs",
    "lint:php:fix": "vendor\\bin\\phpcbf",
    "lint:php:errors": "vendor\\bin\\phpcs -n",
    "prepare": "husky"
  },
  "keywords": [
    "wordpress",
    "tailwind"
  ],
  "author": "Julian C Dev",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.19.12",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
